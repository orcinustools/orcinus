// Orcinus forks kompose (see third_party/kompose) so the compose conversion
// engine stays fully under our control and Docker Compose compatible.
replace github.com/kubernetes/kompose => ./third_party/kompose

// Inherited from the kompose module (Go ignores replaces in non-main modules).
replace github.com/openshift/api v3.9.0+incompatible => github.com/openshift/api v0.0.0-20230704153349-abb98ff04d03
